<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#202426" />
            <stroke android:width="1dp" android:color="#343A38" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#353C3E" />
            <stroke android:width="1dp" android:color="@color/text_secondary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/surface_raised" />
            <stroke android:width="1dp" android:color="@color/border" />
        </shape>
    </item>
</selector>
