<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:colorAccent">@color/accent</item>
    </style>

    <style name="ActionButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-medium</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="BackendSegment">
        <item name="android:button">@null</item>
        <item name="android:background">@drawable/backend_segment</item>
        <item name="android:textColor">@color/backend_segment_text</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-medium</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
