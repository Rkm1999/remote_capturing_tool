<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="21sp"
                android:fontFamily="sans-medium"
                android:letterSpacing="0" />

            <TextView
                android:id="@+id/session_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/ready"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/chip_background"
            android:gravity="center"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="@string/tile_size"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-medium"
            android:letterSpacing="0" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/preview_background">

        <ImageView
            android:id="@+id/image_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:contentDescription="@string/image_preview"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/empty_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/select_an_image"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:letterSpacing="0" />
    </FrameLayout>

    <TextView
        android:id="@+id/image_details"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:ellipsize="middle"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:text="@string/no_image_selected"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:letterSpacing="0" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="14dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/accelerator"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-medium"
            android:letterSpacing="0" />

        <RadioGroup
            android:id="@+id/backend_group"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:checkedButton="@id/backend_gpu"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/backend_gpu"
                style="@style/BackendSegment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/gpu" />

            <RadioButton
                android:id="@+id/backend_npu"
                style="@style/BackendSegment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/npu" />

            <RadioButton
                android:id="@+id/backend_dual"
                style="@style/BackendSegment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/gpu_npu" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="sans-medium"
            android:letterSpacing="0"
            android:text="@string/model_quality"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <RadioGroup
            android:id="@+id/quality_group"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:checkedButton="@id/quality_high"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/quality_fast"
                style="@style/BackendSegment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/high_performance_8bit" />

            <RadioButton
                android:id="@+id/quality_high"
                style="@style/BackendSegment"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/high_quality_16bit" />
        </RadioGroup>

        <Switch
            android:id="@+id/high_overlap_switch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/high_overlap"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:buttonTint="@color/accent"
            android:letterSpacing="0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/progress_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/ready"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:letterSpacing="0" />

            <TextView
                android:id="@+id/progress_percent"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-medium"
                android:letterSpacing="0" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:indeterminate="false"
            android:max="1000"
            android:progress="0"
            android:progressBackgroundTint="@color/surface_raised"
            android:progressTint="@color/accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/choose_button"
                style="@style/ActionButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/button_secondary"
                android:text="@string/choose_image"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/run_button"
                style="@style/ActionButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary"
                android:enabled="false"
                android:text="@string/run_denoise"
                android:textColor="#10251C" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cancel_button"
                style="@style/ActionButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/button_secondary"
                android:text="@string/cancel"
                android:textColor="@color/warning"
                android:visibility="gone" />

            <Button
                android:id="@+id/save_button"
                style="@style/ActionButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/button_secondary"
                android:enabled="false"
                android:text="@string/save_image"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
